generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================
enum UserStatus {
  active
  suspended
  invited
}

enum UserRole {
  admin
  developer
  viewer
}

enum WorkflowStatus {
  draft
  active
  archived
}

enum ConversationStatus {
  active
  completed
  failed
  archived
}

enum ErrorCategory {
  timeout
  rate_limit
  context_overflow
  budget_exceeded
  tool_error
  permission_denied
  unknown
}

enum StepErrorHandler {
  fail
  skip
  fallback
  continue_next
}

enum TriggerType {
  manual
  cron
  webhook_inbound
  event
  git_push
}

enum OveragePolicy {
  block
  warn
  allow
}

enum ResourceType {
  mcp_server
  skill
  agent
  rule
  hook
  plugin
  workflow
}

// ============================================
// USERS
// ============================================
model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String     @map("password_hash")
  name         String?
  githubToken  String?    @map("github_token")
  status       UserStatus @default(active)
  role         UserRole   @default(developer)
  preferences  Json       @default("{}")
  lastLoginAt  DateTime?  @map("last_login_at")
  maxConcurrentExecutions Int @default(5) @map("max_concurrent_executions")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @default(now()) @updatedAt @map("updated_at")

  workflows     Workflow[]
  conversations Conversation[]
  mcpServers    McpServer[]
  skills        Skill[]
  agents        Agent[]
  rules         Rule[]
  plugins       Plugin[]
  hooks         Hook[]
  apiKeys       ApiKey[]
  tokenBudget   UserTokenBudget?
  webhooks      Webhook[]
  promptVersions PromptVersion[]
  gitAccounts   GitAccount[]
  tokenUsageHistory TokenUsageHistory[]
  auditLogs     AuditLog[]
  tags          Tag[]
  stepTemplates StepTemplate[]

  @@map("users")
}

// ============================================
// API KEYS (for MCP Server & external access)
// ============================================
model ApiKey {
  id        String    @id @default(uuid())
  name      String
  keyHash   String    @unique @map("key_hash")
  prefix    String    // first 8 chars for identification (e.g. "exk_abc1")
  scopes    Json      @default("[]") // JSON array of allowed scopes
  rateLimit Int?      @map("rate_limit") // requests per minute
  usageCount Int      @default(0) @map("usage_count")
  ipWhitelist Json    @default("[]") @map("ip_whitelist") // JSON array of allowed IPs
  lastUsedAt DateTime? @map("last_used_at")
  expiresAt DateTime?  @map("expires_at")
  revoked   Boolean   @default(false)
  createdAt DateTime  @default(now()) @map("created_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([keyHash])
  @@map("api_keys")
}

// ============================================
// WORKFLOWS
// ============================================
model Workflow {
  id          String         @id @default(uuid())
  name        String
  description String?
  type        String         @default("sequential")
  status      WorkflowStatus @default(active)
  tags        Json           @default("[]")
  lastExecutedAt DateTime?   @map("last_executed_at")
  executionCount Int         @default(0) @map("execution_count")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @default(now()) @updatedAt @map("updated_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  steps         WorkflowStep[]
  conversations Conversation[]
  versions      WorkflowVersion[]
  triggers      WorkflowTrigger[]

  @@index([userId])
  @@map("workflows")
}

model WorkflowStep {
  id         String @id @default(uuid())
  workflowId String @map("workflow_id")
  name       String
  baseUrl    String @map("base_url")
  stepOrder  Int    @map("step_order")

  // Prompts
  systemPrompt       String?  @map("system_prompt")
  useBasePrompt      Boolean  @default(true) @map("use_base_prompt")

  // Conditions (now native Json)
  conditions Json @default("{}")
  maxRetries Int  @default(0) @map("max_retries")

  // DAG dependencies (Json array of step IDs)
  dependsOn Json @default("[]") @map("depends_on")

  // Validators (Json array of validator configs)
  validators Json @default("[]")

  // Step Templates
  templateId      String? @map("template_id")
  outputVariables Json    @default("[]") @map("output_variables")
  inputVariables  Json    @default("[]") @map("input_variables")

  // Multi-backend support
  backend String  @default("claude")
  model   String?

  // Error handling & timeout
  timeout      Int?             @default(300000) // ms, default 5min
  errorHandler StepErrorHandler @default(fail) @map("error_handler")
  skipCondition String?         @map("skip_condition") // expression to evaluate
  subWorkflowId String?         @map("sub_workflow_id") // for sub-workflow steps
  outputSchema  Json?           @map("output_schema") // expected output JSON schema

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  workflow             Workflow              @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  messages             Message[]
  conversationSessions ConversationSession[]
  stepMemories         StepMemory[]
  currentConversations Conversation[]        @relation("CurrentStep")
  executionLogs        ExecutionLog[]
  executionTraces      ExecutionTrace[]
  promptVersions       PromptVersion[]

  // Join tables for MCP/Skills/Agents/Rules/Hooks
  mcpServers WorkflowStepMcpServer[]
  skills     WorkflowStepSkill[]
  agents     WorkflowStepAgent[]
  rules      WorkflowStepRule[]
  hooks      WorkflowStepHook[]

  @@index([workflowId])
  @@map("workflow_steps")
}

// ============================================
// WORKFLOW VERSIONS
// ============================================
model WorkflowVersion {
  id          String   @id @default(uuid())
  version     Int
  snapshot    Json     // complete workflow+steps snapshot
  diff        Json?    // structural diff from previous version
  changelog   String?
  createdAt   DateTime @default(now()) @map("created_at")

  workflowId String   @map("workflow_id")
  workflow   Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, version])
  @@index([workflowId])
  @@map("workflow_versions")
}

// ============================================
// CONVERSATIONS
// ============================================
model Conversation {
  id             String             @id @default(uuid())
  title          String?
  projectPath    String?            @map("project_path")
  status         ConversationStatus @default(active)
  totalTokensUsed Int               @default(0) @map("total_tokens_used")
  totalCostUsd   Float?             @map("total_cost_usd")
  lastMessageAt  DateTime?          @map("last_message_at")
  isArchived     Boolean            @default(false) @map("is_archived")
  tags           Json               @default("[]")
  parentId       String?            @map("parent_id") // fork support
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @default(now()) @updatedAt @map("updated_at")

  // Relations
  userId        String       @map("user_id")
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  workflowId    String       @map("workflow_id")
  workflow      Workflow     @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  currentStepId String?      @map("current_step_id")
  currentStep   WorkflowStep? @relation("CurrentStep", fields: [currentStepId], references: [id], onDelete: SetNull)

  // Reverse relations
  messages        Message[]
  sessions        ConversationSession[]
  stepMemories    StepMemory[]
  executionStates ExecutionState[]
  executionLogs   ExecutionLog[]
  executionTraces ExecutionTrace[]
  messageFeedbacks MessageFeedback[]

  @@index([userId])
  @@index([workflowId])
  @@index([status])
  @@map("conversations")
}

// ============================================
// MESSAGES
// ============================================
model Message {
  id                 String  @id @default(uuid())
  role               String
  content            String
  selectedForContext Boolean @default(false) @map("selected_for_context")
  metadata           Json?
  tokenCount         Int?    @map("token_count")
  model              String?
  createdAt          DateTime @default(now()) @map("created_at")

  // Relations
  conversationId String       @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  stepId         String?      @map("step_id")
  step           WorkflowStep? @relation(fields: [stepId], references: [id], onDelete: SetNull)
  attachments    MessageAttachment[]
  feedbacks      MessageFeedback[]

  @@index([conversationId])
  @@index([conversationId, stepId])
  @@index([stepId])
  @@map("messages")
}

// ============================================
// MESSAGE FEEDBACK
// ============================================
model MessageFeedback {
  id        String   @id @default(uuid())
  rating    Int      // 1-5
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  messageId      String       @map("message_id")
  message        Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  conversationId String       @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([conversationId])
  @@map("message_feedbacks")
}

// ============================================
// MESSAGE ATTACHMENTS (Images)
// ============================================
model MessageAttachment {
  id          String   @id @default(uuid())
  filename    String
  mimeType    String   @map("mime_type")
  size        Int      // bytes
  path        String   // relative path on disk
  projectPath String   @map("project_path") // absolute path in project dir (for Claude CLI)
  url         String   @default("") // URL to serve the file
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  messageId String  @map("message_id")
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("message_attachments")
}

// ============================================
// SESSIONS (Claude CLI)
// ============================================
model ConversationSession {
  id              String   @id @default(uuid())
  claudeSessionId String   @map("claude_session_id")
  createdAt       DateTime @default(now()) @map("created_at")

  // Relations
  conversationId String       @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  stepId         String       @map("step_id")
  step           WorkflowStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@unique([conversationId, stepId])
  @@index([conversationId, stepId])
  @@map("conversation_sessions")
}

// ============================================
// STEP MEMORY (Context persistence across compactions)
// ============================================
model StepMemory {
  id        String   @id @default(uuid())
  content   String   // Resumo acumulado da conversa para este step
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  // Relations
  conversationId String       @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  stepId         String       @map("step_id")
  step           WorkflowStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@unique([conversationId, stepId])
  @@index([conversationId, stepId])
  @@map("step_memories")
}

// ============================================
// EXECUTION STATE (Orchestrator)
// ============================================
model ExecutionState {
  id               String   @id
  state            String   @default("queued")
  currentStepIndex Int      @default(0) @map("current_step_index")
  retryCounts      Json     @default("{}") @map("retry_counts")
  metadata         Json     @default("{}")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")

  // Relations
  conversationId String       @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([state])
  @@map("execution_state")
}

// ============================================
// EXECUTION LOGS (Audit Trail)
// ============================================
model ExecutionLog {
  id          String   @id @default(uuid())
  executionId String   @map("execution_id")
  eventType   String   @map("event_type")
  stepId      String?  @map("step_id")
  stepName    String?  @map("step_name")
  data        Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  conversationId String        @map("conversation_id")
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  step           WorkflowStep? @relation(fields: [stepId], references: [id], onDelete: SetNull)

  @@index([executionId])
  @@index([executionId, eventType])
  @@index([conversationId])
  @@map("execution_logs")
}

// ============================================
// MCP SERVERS
// ============================================
model McpServer {
  id          String   @id @default(uuid())
  name        String
  description String?
  type        String   @default("http") // http | sse | stdio
  uri         String?
  command     String?
  args        Json     @default("[]")
  envVars     Json     @default("{}") @map("env_vars")
  enabled     Boolean  @default(true)
  isGlobal    Boolean  @default(false) @map("is_global")
  toolsCache  Json?    @map("tools_cache")
  lastTestAt  DateTime? @map("last_test_at")
  lastTestOk  Boolean?  @map("last_test_ok")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stepServers WorkflowStepMcpServer[]
  pluginId    String?  @map("plugin_id")
  plugin      Plugin?  @relation(fields: [pluginId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("mcp_servers")
}

// ============================================
// SKILLS
// ============================================
model Skill {
  id           String   @id @default(uuid())
  name         String
  description  String?
  frontmatter  Json     @default("{}")
  body         String   @default("")
  allowedTools Json     @default("[]") @map("allowed_tools")
  model        String?
  enabled      Boolean  @default(true)
  isGlobal     Boolean  @default(false) @map("is_global")
  source       String   @default("manual") // manual | imported
  repoUrl      String?  @map("repo_url")
  projectPath  String?  @map("project_path")

  // Structured GitHub tracking
  repoOwner    String?  @map("repo_owner")
  repoName     String?  @map("repo_name")
  repoBranch   String?  @default("main") @map("repo_branch")
  repoPath     String?  @map("repo_path")
  fileManifest Json     @default("[]") @map("file_manifest")
  lastSyncedAt DateTime? @map("last_synced_at")

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stepSkills WorkflowStepSkill[]
  rules      Rule[]
  pluginId   String?  @map("plugin_id")
  plugin     Plugin?  @relation(fields: [pluginId], references: [id], onDelete: SetNull)

  @@unique([name, userId])
  @@index([userId])
  @@map("skills")
}

// ============================================
// AGENTS
// ============================================
model Agent {
  id              String   @id @default(uuid())
  name            String
  description     String?
  systemPrompt    String   @default("") @map("system_prompt")
  tools           Json     @default("[]")
  disallowedTools Json     @default("[]") @map("disallowed_tools")
  model           String?
  permissionMode  String   @default("default") @map("permission_mode")
  maxTurns        Int?     @map("max_turns")
  skills          Json     @default("[]")
  enabled         Boolean  @default(true)
  isGlobal        Boolean  @default(false) @map("is_global")
  source          String   @default("manual") // manual | imported
  repoUrl         String?  @map("repo_url")
  projectPath     String?  @map("project_path")

  // Structured GitHub tracking
  repoOwner    String?  @map("repo_owner")
  repoName     String?  @map("repo_name")
  repoBranch   String?  @default("main") @map("repo_branch")
  repoPath     String?  @map("repo_path")
  lastSyncedAt DateTime? @map("last_synced_at")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stepAgents WorkflowStepAgent[]
  pluginId   String?  @map("plugin_id")
  plugin     Plugin?  @relation(fields: [pluginId], references: [id], onDelete: SetNull)

  @@unique([name, userId])
  @@index([userId])
  @@map("agents")
}

// ============================================
// RULES
// ============================================
model Rule {
  id          String   @id @default(uuid())
  name        String
  description String?
  body        String   @default("")
  enabled     Boolean  @default(true)
  isGlobal    Boolean  @default(false) @map("is_global")
  source      String   @default("manual")
  repoUrl     String?  @map("repo_url")
  projectPath String?  @map("project_path")

  // Structured GitHub tracking
  repoOwner    String?  @map("repo_owner")
  repoName     String?  @map("repo_name")
  repoBranch   String?  @default("main") @map("repo_branch")
  repoPath     String?  @map("repo_path")
  lastSyncedAt DateTime? @map("last_synced_at")

  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillId     String?  @map("skill_id")
  skill       Skill?   @relation(fields: [skillId], references: [id], onDelete: SetNull)
  pluginId    String?  @map("plugin_id")
  plugin      Plugin?  @relation(fields: [pluginId], references: [id], onDelete: SetNull)
  stepRules   WorkflowStepRule[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([name, userId])
  @@index([userId])
  @@map("rules")
}

// ============================================
// PLUGINS
// ============================================
model Plugin {
  id          String   @id @default(uuid())
  name        String
  description String?
  version     String?
  author      String?
  manifest    Json     @default("{}")
  enabled     Boolean  @default(true)
  source      String   @default("manual") // manual | imported
  repoUrl     String?  @map("repo_url")
  projectPath String?  @map("project_path")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mcpServers McpServer[]
  skills     Skill[]
  agents     Agent[]
  rules      Rule[]

  @@unique([name, userId])
  @@index([userId])
  @@map("plugins")
}

// ============================================
// EXECUTION TRACES (Monitoring)
// ============================================
model ExecutionTrace {
  id             String    @id @default(uuid())
  executionId    String    @map("execution_id")
  conversationId String    @map("conversation_id")
  stepId         String    @map("step_id")

  // Input
  commandLine    String    @map("command_line")
  envSnapshot    Json      @default("{}") @map("env_snapshot")
  messageLength  Int       @map("message_length")
  systemPrompt   String?   @map("system_prompt_preview")
  resumeToken    String?   @map("resume_token")
  model          String?
  projectPath    String    @map("project_path")
  pid            Int?

  // Raw I/O
  stdoutRaw      String    @default("") @map("stdout_raw")
  stderrRaw      String    @default("") @map("stderr_raw")

  // Timeline
  parsedEvents   Json      @default("[]") @map("parsed_events")

  // Timing
  startedAt      DateTime  @map("started_at")
  firstByteAt    DateTime? @map("first_byte_at")
  firstContentAt DateTime? @map("first_content_at")
  completedAt    DateTime? @map("completed_at")
  durationMs     Int?      @map("duration_ms")

  // Result
  exitCode       Int?      @map("exit_code")
  signal         String?
  resultStatus   String    @map("result_status")
  errorMessage   String?   @map("error_message")
  errorCategory  ErrorCategory? @map("error_category")
  errorCode      String?   @map("error_code")
  contentLength  Int       @default(0) @map("content_length")
  actionsCount   Int       @default(0) @map("actions_count")
  resumeTokenOut String?   @map("resume_token_out")

  // Token usage (from stream-json)
  inputTokens  Int @default(0) @map("input_tokens")
  outputTokens Int @default(0) @map("output_tokens")
  cacheCreationInputTokens  Int @default(0) @map("cache_creation_input_tokens")
  cacheReadInputTokens      Int @default(0) @map("cache_read_input_tokens")

  // Server tool usage
  webSearchRequests  Int @default(0) @map("web_search_requests")
  webFetchRequests   Int @default(0) @map("web_fetch_requests")

  // Cost and performance
  totalCostUsd     Float?    @map("total_cost_usd")
  durationApiMs    Int?      @map("duration_api_ms")
  numTurns         Int       @default(0) @map("num_turns")
  stopReason       String?   @map("stop_reason")

  // Claude Code metadata
  claudeCodeVersion String?  @map("claude_code_version")
  outputStyle       String?  @map("output_style")
  fastModeState     String?  @map("fast_mode_state")
  permissionMode    String?  @map("permission_mode")
  sessionId         String?  @map("session_id")

  // Additional metadata (native Json)
  serviceTier       String?   @map("service_tier")
  inferenceGeo      String?   @map("inference_geo")
  iterations        Json      @default("[]")
  modelUsage        Json      @default("{}")  @map("model_usage")
  permissionDenials Json      @default("[]")  @map("permission_denials")
  cacheCreation     Json      @default("{}")  @map("cache_creation")

  createdAt      DateTime  @default(now()) @map("created_at")

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  step           WorkflowStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  promptVersionId String? @map("prompt_version_id")

  toolCalls      ExecutionToolCall[]

  @@index([executionId])
  @@index([conversationId])
  @@index([stepId])
  @@index([createdAt])
  @@map("execution_traces")
}

// ============================================
// EXECUTION TOOL CALLS (Extracted from opaque JSON)
// ============================================
model ExecutionToolCall {
  id          String   @id @default(uuid())
  toolName    String   @map("tool_name")
  input       Json     @default("{}")
  output      Json?
  durationMs  Int?     @map("duration_ms")
  success     Boolean  @default(true)
  errorMessage String? @map("error_message")
  createdAt   DateTime @default(now()) @map("created_at")

  traceId String         @map("trace_id")
  trace   ExecutionTrace @relation(fields: [traceId], references: [id], onDelete: Cascade)

  @@index([traceId])
  @@index([toolName])
  @@map("execution_tool_calls")
}

// ============================================
// EXECUTION AGGREGATE (Cross-step metrics)
// ============================================
model ExecutionAggregate {
  id              String   @id @default(uuid())
  executionId     String   @unique @map("execution_id")
  conversationId  String   @map("conversation_id")
  workflowId      String   @map("workflow_id")
  totalSteps      Int      @default(0) @map("total_steps")
  completedSteps  Int      @default(0) @map("completed_steps")
  failedSteps     Int      @default(0) @map("failed_steps")
  skippedSteps    Int      @default(0) @map("skipped_steps")
  totalInputTokens  Int    @default(0) @map("total_input_tokens")
  totalOutputTokens Int    @default(0) @map("total_output_tokens")
  totalCostUsd    Float?   @map("total_cost_usd")
  totalDurationMs Int?     @map("total_duration_ms")
  startedAt       DateTime @map("started_at")
  completedAt     DateTime? @map("completed_at")
  finalStatus     String   @default("running") @map("final_status")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([conversationId])
  @@index([workflowId])
  @@index([startedAt])
  @@map("execution_aggregates")
}

// ============================================
// DAILY EXECUTION METRICS (Pre-aggregated)
// ============================================
model DailyExecutionMetrics {
  id              String   @id @default(uuid())
  date            DateTime @db.Date
  totalExecutions Int      @default(0) @map("total_executions")
  successCount    Int      @default(0) @map("success_count")
  failureCount    Int      @default(0) @map("failure_count")
  totalInputTokens  Int    @default(0) @map("total_input_tokens")
  totalOutputTokens Int    @default(0) @map("total_output_tokens")
  totalCostUsd    Float    @default(0) @map("total_cost_usd")
  avgDurationMs   Float?   @map("avg_duration_ms")
  p50DurationMs   Float?   @map("p50_duration_ms")
  p95DurationMs   Float?   @map("p95_duration_ms")
  uniqueWorkflows Int      @default(0) @map("unique_workflows")
  uniqueUsers     Int      @default(0) @map("unique_users")
  errorBreakdown  Json     @default("{}") @map("error_breakdown")
  modelBreakdown  Json     @default("{}") @map("model_breakdown")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([date])
  @@index([date])
  @@map("daily_execution_metrics")
}

// ============================================
// HOOKS (Claude Code Hooks)
// ============================================
model Hook {
  id            String   @id @default(uuid())
  name          String
  description   String?
  eventType     String   @map("event_type") // PreToolUse, PostToolUse, Stop, etc.
  matcher       String?  // regex pattern for matchers (tool name, session type, etc.)
  handlerType   String   @default("command") @map("handler_type") // command | prompt | agent
  command       String?  // shell command (for command handler)
  prompt        String?  // prompt text (for prompt/agent handler)
  timeout       Int      @default(60000) // timeout in ms
  isAsync       Boolean  @default(false) @map("is_async")
  statusMessage String?  @map("status_message") // message shown during execution
  enabled       Boolean  @default(true)
  isGlobal      Boolean  @default(false) @map("is_global")
  projectPath   String?  @map("project_path") // project-specific hook
  isTemplate    Boolean  @default(false) @map("is_template") // system template
  templateId    String?  @map("template_id") // if created from template

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stepHooks     WorkflowStepHook[]

  @@index([userId])
  @@index([eventType])
  @@map("hooks")
}

// ============================================
// USER TOKEN BUDGET
// ============================================
model UserTokenBudget {
  id                  String        @id @default(uuid())
  dailyLimit          Int           @default(5000000) @map("daily_limit")
  monthlyLimit        Int           @default(100000000) @map("monthly_limit")
  currentDailyUsage   Int           @default(0) @map("current_daily_usage")
  currentMonthlyUsage Int           @default(0) @map("current_monthly_usage")
  lastDailyResetAt    DateTime      @default(now()) @map("last_daily_reset_at")
  lastMonthlyResetAt  DateTime      @default(now()) @map("last_monthly_reset_at")
  dailyCostLimitUsd   Float?        @map("daily_cost_limit_usd")
  monthlyCostLimitUsd Float?        @map("monthly_cost_limit_usd")
  overagePolicy       OveragePolicy @default(block) @map("overage_policy")

  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_token_budgets")
}

// ============================================
// TOKEN USAGE HISTORY (Audit trail)
// ============================================
model TokenUsageHistory {
  id           String   @id @default(uuid())
  inputTokens  Int      @map("input_tokens")
  outputTokens Int      @map("output_tokens")
  totalCostUsd Float?   @map("total_cost_usd")
  model        String?
  executionId  String?  @map("execution_id")
  createdAt    DateTime @default(now()) @map("created_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("token_usage_history")
}

// ============================================
// STEP TEMPLATES
// ============================================
model StepTemplate {
  id           String   @id @default(uuid())
  name         String
  description  String?
  baseUrl      String   @default("") @map("base_url")
  systemPrompt String?  @map("system_prompt")
  conditions   Json     @default("{}")
  resourceIds  Json     @default("{}") @map("resource_ids")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([name, userId])
  @@index([userId])
  @@map("step_templates")
}

// ============================================
// PROMPT VERSIONS
// ============================================
model PromptVersion {
  id        String   @id @default(uuid())
  stepId    String   @map("step_id")
  version   Int
  content   String
  diff      String?
  createdAt DateTime @default(now()) @map("created_at")

  createdBy String @map("created_by")
  creator   User   @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  step      WorkflowStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@index([stepId])
  @@map("prompt_versions")
}

// ============================================
// WEBHOOKS
// ============================================
model Webhook {
  id        String   @id @default(uuid())
  url       String
  events    Json     @default("[]")
  secret    String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  userId     String            @map("user_id")
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([userId])
  @@map("webhooks")
}

model WebhookDelivery {
  id           String   @id @default(uuid())
  payload      Json
  responseCode Int?     @map("response_code")
  responseBody String?  @map("response_body")
  attempts     Int      @default(0)
  status       String   @default("pending") // pending | success | failed
  createdAt    DateTime @default(now()) @map("created_at")
  completedAt  DateTime? @map("completed_at")

  webhookId String  @map("webhook_id")
  webhook   Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@map("webhook_deliveries")
}

// ============================================
// WORKFLOW TRIGGERS
// ============================================
model WorkflowTrigger {
  id           String      @id @default(uuid())
  type         TriggerType @default(manual)
  cronExpr     String?     @map("cron_expr") // cron expression
  cronTimezone String?     @map("cron_timezone") // e.g. "America/Sao_Paulo"
  webhookSecret String?    @map("webhook_secret")
  eventName    String?     @map("event_name") // e.g. "workflow_complete", "step_failed"
  eventFilter  Json?       @map("event_filter") // filter conditions for event
  rateLimit    Int?        @map("rate_limit") // max triggers per hour
  enabled      Boolean     @default(true)
  lastTriggeredAt DateTime? @map("last_triggered_at")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @default(now()) @updatedAt @map("updated_at")

  workflowId String   @map("workflow_id")
  workflow   Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  scheduledExecutions ScheduledExecution[]

  @@index([workflowId])
  @@index([type])
  @@map("workflow_triggers")
}

// ============================================
// SCHEDULED EXECUTIONS
// ============================================
model ScheduledExecution {
  id          String    @id @default(uuid())
  scheduledAt DateTime  @map("scheduled_at")
  executedAt  DateTime? @map("executed_at")
  status      String    @default("pending") // pending | running | completed | failed | cancelled
  result      Json?
  errorMessage String?  @map("error_message")
  createdAt   DateTime  @default(now()) @map("created_at")

  triggerId String          @map("trigger_id")
  trigger   WorkflowTrigger @relation(fields: [triggerId], references: [id], onDelete: Cascade)

  @@index([triggerId])
  @@index([scheduledAt])
  @@index([status])
  @@map("scheduled_executions")
}

// ============================================
// AUDIT LOG (Global)
// ============================================
model AuditLog {
  id           String       @id @default(uuid())
  action       String       // create, update, delete, execute, login, etc.
  resourceType ResourceType @map("resource_type")
  resourceId   String       @map("resource_id")
  resourceName String?      @map("resource_name")
  diff         Json?        // changes diff {before, after}
  metadata     Json?
  ipAddress    String?      @map("ip_address")
  createdAt    DateTime     @default(now()) @map("created_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([resourceType, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================
// TAGS (Universal)
// ============================================
model Tag {
  id        String   @id @default(uuid())
  name      String
  color     String?  // hex color
  createdAt DateTime @default(now()) @map("created_at")

  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  resources ResourceTag[]

  @@unique([name, userId])
  @@index([userId])
  @@map("tags")
}

// ============================================
// RESOURCE TAGS (Universal join)
// ============================================
model ResourceTag {
  id           String       @id @default(uuid())
  resourceType ResourceType @map("resource_type")
  resourceId   String       @map("resource_id")
  createdAt    DateTime     @default(now()) @map("created_at")

  tagId String @map("tag_id")
  tag   Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([tagId, resourceType, resourceId])
  @@index([resourceType, resourceId])
  @@map("resource_tags")
}

// ============================================
// RESOURCE DEPENDENCIES (Declarative)
// ============================================
model ResourceDependency {
  id               String       @id @default(uuid())
  sourceType       ResourceType @map("source_type")
  sourceId         String       @map("source_id")
  dependencyType   ResourceType @map("dependency_type")
  dependencyId     String       @map("dependency_id")
  dependencyName   String?      @map("dependency_name")
  isOptional       Boolean      @default(false) @map("is_optional")
  createdAt        DateTime     @default(now()) @map("created_at")

  @@unique([sourceType, sourceId, dependencyType, dependencyId])
  @@index([sourceType, sourceId])
  @@index([dependencyType, dependencyId])
  @@map("resource_dependencies")
}

// ============================================
// JOIN TABLES (Enriched)
// ============================================
model WorkflowStepMcpServer {
  id        String       @id @default(uuid())
  stepId    String       @map("step_id")
  serverId  String       @map("server_id")
  order     Int          @default(0)
  config    Json?
  createdAt DateTime     @default(now()) @map("created_at")
  step      WorkflowStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  server    McpServer    @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([stepId, serverId])
  @@map("workflow_step_mcp_servers")
}

model WorkflowStepSkill {
  id        String       @id @default(uuid())
  stepId    String       @map("step_id")
  skillId   String       @map("skill_id")
  order     Int          @default(0)
  config    Json?
  createdAt DateTime     @default(now()) @map("created_at")
  step      WorkflowStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  skill     Skill        @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([stepId, skillId])
  @@map("workflow_step_skills")
}

model WorkflowStepAgent {
  id        String       @id @default(uuid())
  stepId    String       @map("step_id")
  agentId   String       @map("agent_id")
  order     Int          @default(0)
  config    Json?
  createdAt DateTime     @default(now()) @map("created_at")
  step      WorkflowStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  agent     Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([stepId, agentId])
  @@map("workflow_step_agents")
}

model WorkflowStepRule {
  id        String       @id @default(uuid())
  stepId    String       @map("step_id")
  ruleId    String       @map("rule_id")
  order     Int          @default(0)
  createdAt DateTime     @default(now()) @map("created_at")
  step      WorkflowStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  rule      Rule         @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([stepId, ruleId])
  @@map("workflow_step_rules")
}

model WorkflowStepHook {
  id        String       @id @default(uuid())
  stepId    String       @map("step_id")
  hookId    String       @map("hook_id")
  order     Int          @default(0)
  createdAt DateTime     @default(now()) @map("created_at")
  step      WorkflowStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  hook      Hook         @relation(fields: [hookId], references: [id], onDelete: Cascade)

  @@unique([stepId, hookId])
  @@map("workflow_step_hooks")
}

// ============================================
// GIT ACCOUNTS (Multiple GitHub accounts per user)
// ============================================
model GitAccount {
  id        String   @id @default(uuid())
  label     String   // e.g. "Pessoal", "Trabalho"
  token     String
  username  String?  // cached GitHub username
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectMappings ProjectGitMapping[]

  @@unique([label, userId])
  @@index([userId])
  @@map("git_accounts")
}

// ============================================
// PROJECT GIT MAPPING (project path -> git account)
// ============================================
model ProjectGitMapping {
  id           String     @id @default(uuid())
  projectPath  String     @unique @map("project_path")
  createdAt    DateTime   @default(now()) @map("created_at")

  gitAccountId String     @map("git_account_id")
  gitAccount   GitAccount @relation(fields: [gitAccountId], references: [id], onDelete: Cascade)

  @@index([gitAccountId])
  @@map("project_git_mappings")
}
