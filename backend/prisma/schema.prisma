generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USERS
// ============================================
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  githubToken  String?  @map("github_token")
  role         String   @default("developer") // admin | developer | viewer
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  workflows     Workflow[]
  conversations Conversation[]
  mcpServers    McpServer[]
  skills        Skill[]
  agents        Agent[]
  rules         Rule[]
  plugins       Plugin[]
  hooks         Hook[]
  apiKeys       ApiKey[]
  tokenBudget   UserTokenBudget?
  webhooks      Webhook[]
  promptVersions PromptVersion[]

  @@map("users")
}

// ============================================
// API KEYS (for MCP Server & external access)
// ============================================
model ApiKey {
  id        String    @id @default(uuid())
  name      String
  keyHash   String    @unique @map("key_hash")
  prefix    String    // first 8 chars for identification (e.g. "exk_abc1")
  lastUsedAt DateTime? @map("last_used_at")
  expiresAt DateTime?  @map("expires_at")
  revoked   Boolean   @default(false)
  createdAt DateTime  @default(now()) @map("created_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([keyHash])
  @@map("api_keys")
}

// ============================================
// WORKFLOWS
// ============================================
model Workflow {
  id          String       @id @default(uuid())
  name        String
  description String?
  type        String       @default("sequential")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @default(now()) @updatedAt @map("updated_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  steps         WorkflowStep[]
  conversations Conversation[]

  @@index([userId])
  @@map("workflows")
}

model WorkflowStep {
  id         String @id @default(uuid())
  workflowId String @map("workflow_id")
  name       String
  baseUrl    String @map("base_url")
  stepOrder  Int    @map("step_order")

  // Prompts
  systemPrompt       String? @map("system_prompt")

  // Conditions
  conditions String @default("{}")
  maxRetries Int    @default(0) @map("max_retries")

  // DAG dependencies (JSON array of step IDs)
  dependsOn String @default("[]") @map("depends_on")

  // Validators (JSON array of validator configs)
  validators String @default("[]")

  // Step Templates
  templateId      String? @map("template_id")
  outputVariables String  @default("[]") @map("output_variables")
  inputVariables  String  @default("[]") @map("input_variables")

  // Multi-backend support
  backend String  @default("claude")
  model   String?

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  workflow             Workflow              @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  messages             Message[]
  conversationSessions ConversationSession[]
  currentConversations Conversation[]        @relation("CurrentStep")
  executionLogs        ExecutionLog[]

  // Join tables for MCP/Skills/Agents/Rules/Hooks
  mcpServers WorkflowStepMcpServer[]
  skills     WorkflowStepSkill[]
  agents     WorkflowStepAgent[]
  rules      WorkflowStepRule[]
  hooks      WorkflowStepHook[]

  @@index([workflowId])
  @@map("workflow_steps")
}

// ============================================
// CONVERSATIONS
// ============================================
model Conversation {
  id          String   @id @default(uuid())
  title       String?
  projectPath String?  @map("project_path")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  // Relations
  userId        String       @map("user_id")
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  workflowId    String       @map("workflow_id")
  workflow      Workflow     @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  currentStepId String?      @map("current_step_id")
  currentStep   WorkflowStep? @relation("CurrentStep", fields: [currentStepId], references: [id], onDelete: SetNull)

  // Reverse relations
  messages        Message[]
  sessions        ConversationSession[]
  executionStates ExecutionState[]
  executionLogs   ExecutionLog[]
  executionTraces ExecutionTrace[]

  @@index([userId])
  @@index([workflowId])
  @@map("conversations")
}

// ============================================
// MESSAGES
// ============================================
model Message {
  id                 String  @id @default(uuid())
  role               String
  content            String
  selectedForContext Boolean @default(false) @map("selected_for_context")
  metadata           String?
  createdAt          DateTime @default(now()) @map("created_at")

  // Relations
  conversationId String       @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  stepId         String?      @map("step_id")
  step           WorkflowStep? @relation(fields: [stepId], references: [id], onDelete: SetNull)
  attachments    MessageAttachment[]

  @@index([conversationId])
  @@index([conversationId, stepId])
  @@index([stepId])
  @@map("messages")
}

// ============================================
// MESSAGE ATTACHMENTS (Images)
// ============================================
model MessageAttachment {
  id          String   @id @default(uuid())
  filename    String
  mimeType    String   @map("mime_type")
  size        Int      // bytes
  path        String   // relative path on disk
  projectPath String   @map("project_path") // absolute path in project dir (for Claude CLI)
  url         String   @default("") // URL to serve the file
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  messageId String  @map("message_id")
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("message_attachments")
}

// ============================================
// SESSIONS (Claude CLI)
// ============================================
model ConversationSession {
  id              String   @id @default(uuid())
  claudeSessionId String   @map("claude_session_id")
  createdAt       DateTime @default(now()) @map("created_at")

  // Relations
  conversationId String       @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  stepId         String       @map("step_id")
  step           WorkflowStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@unique([conversationId, stepId])
  @@index([conversationId, stepId])
  @@map("conversation_sessions")
}

// ============================================
// EXECUTION STATE (Orchestrator)
// ============================================
model ExecutionState {
  id               String   @id
  state            String   @default("queued")
  currentStepIndex Int      @default(0) @map("current_step_index")
  retryCounts      String   @default("{}") @map("retry_counts")
  metadata         String   @default("{}")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")

  // Relations
  conversationId String       @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([state])
  @@map("execution_state")
}

// ============================================
// EXECUTION LOGS (Audit Trail)
// ============================================
model ExecutionLog {
  id          String   @id @default(uuid())
  executionId String   @map("execution_id")
  eventType   String   @map("event_type")
  stepId      String?  @map("step_id")
  stepName    String?  @map("step_name")
  data        String   @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  conversationId String        @map("conversation_id")
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  step           WorkflowStep? @relation(fields: [stepId], references: [id], onDelete: SetNull)

  @@index([executionId])
  @@index([executionId, eventType])
  @@index([conversationId])
  @@map("execution_logs")
}

// ============================================
// MCP SERVERS
// ============================================
model McpServer {
  id          String   @id @default(uuid())
  name        String
  description String?
  type        String   @default("http") // http | sse | stdio
  uri         String?
  command     String?
  args        String   @default("[]")
  envVars     String   @default("{}") @map("env_vars")
  enabled     Boolean  @default(true)
  isGlobal    Boolean  @default(false) @map("is_global")
  toolsCache  String?  @map("tools_cache")
  lastTestAt  DateTime? @map("last_test_at")
  lastTestOk  Boolean?  @map("last_test_ok")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stepServers WorkflowStepMcpServer[]
  pluginId    String?  @map("plugin_id")
  plugin      Plugin?  @relation(fields: [pluginId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("mcp_servers")
}

// ============================================
// SKILLS
// ============================================
model Skill {
  id           String   @id @default(uuid())
  name         String
  description  String?
  frontmatter  String   @default("{}")
  body         String   @default("")
  allowedTools String   @default("[]") @map("allowed_tools")
  model        String?
  enabled      Boolean  @default(true)
  isGlobal     Boolean  @default(false) @map("is_global")
  source       String   @default("manual") // manual | imported
  repoUrl      String?  @map("repo_url")
  projectPath  String?  @map("project_path")

  // Structured GitHub tracking
  repoOwner    String?  @map("repo_owner")
  repoName     String?  @map("repo_name")
  repoBranch   String?  @default("main") @map("repo_branch")
  repoPath     String?  @map("repo_path")     // path within repo to skill dir
  fileManifest String   @default("[]") @map("file_manifest") // JSON [{path,content}] all skill files
  lastSyncedAt DateTime? @map("last_synced_at")

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stepSkills WorkflowStepSkill[]
  rules      Rule[]
  pluginId   String?  @map("plugin_id")
  plugin     Plugin?  @relation(fields: [pluginId], references: [id], onDelete: SetNull)

  @@unique([name, userId])
  @@index([userId])
  @@map("skills")
}

// ============================================
// AGENTS
// ============================================
model Agent {
  id              String   @id @default(uuid())
  name            String
  description     String?
  systemPrompt    String   @default("") @map("system_prompt")
  tools           String   @default("[]")
  disallowedTools String   @default("[]") @map("disallowed_tools")
  model           String?
  permissionMode  String   @default("default") @map("permission_mode")
  maxTurns        Int?     @map("max_turns")
  skills          String   @default("[]")
  enabled         Boolean  @default(true)
  isGlobal        Boolean  @default(false) @map("is_global")
  source          String   @default("manual") // manual | imported
  repoUrl         String?  @map("repo_url")
  projectPath     String?  @map("project_path")

  // Structured GitHub tracking
  repoOwner    String?  @map("repo_owner")
  repoName     String?  @map("repo_name")
  repoBranch   String?  @default("main") @map("repo_branch")
  repoPath     String?  @map("repo_path")
  lastSyncedAt DateTime? @map("last_synced_at")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stepAgents WorkflowStepAgent[]
  pluginId   String?  @map("plugin_id")
  plugin     Plugin?  @relation(fields: [pluginId], references: [id], onDelete: SetNull)

  @@unique([name, userId])
  @@index([userId])
  @@map("agents")
}

// ============================================
// RULES
// ============================================
model Rule {
  id          String   @id @default(uuid())
  name        String
  description String?
  body        String   @default("")
  enabled     Boolean  @default(true)
  isGlobal    Boolean  @default(false) @map("is_global")
  source      String   @default("manual")
  repoUrl     String?  @map("repo_url")
  projectPath String?  @map("project_path")

  // Structured GitHub tracking
  repoOwner    String?  @map("repo_owner")
  repoName     String?  @map("repo_name")
  repoBranch   String?  @default("main") @map("repo_branch")
  repoPath     String?  @map("repo_path")
  lastSyncedAt DateTime? @map("last_synced_at")

  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillId     String?  @map("skill_id")
  skill       Skill?   @relation(fields: [skillId], references: [id], onDelete: SetNull)
  pluginId    String?  @map("plugin_id")
  plugin      Plugin?  @relation(fields: [pluginId], references: [id], onDelete: SetNull)
  stepRules   WorkflowStepRule[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([name, userId])
  @@index([userId])
  @@map("rules")
}

// ============================================
// PLUGINS
// ============================================
model Plugin {
  id          String   @id @default(uuid())
  name        String
  description String?
  version     String?
  author      String?
  manifest    String   @default("{}")
  enabled     Boolean  @default(true)
  source      String   @default("manual") // manual | imported
  repoUrl     String?  @map("repo_url")
  projectPath String?  @map("project_path")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mcpServers McpServer[]
  skills     Skill[]
  agents     Agent[]
  rules      Rule[]

  @@unique([name, userId])
  @@index([userId])
  @@map("plugins")
}


// ============================================
// EXECUTION TRACES (Monitoring)
// ============================================
model ExecutionTrace {
  id             String    @id @default(uuid())
  executionId    String    @map("execution_id")
  conversationId String    @map("conversation_id")
  stepId         String    @map("step_id")

  // Input
  commandLine    String    @map("command_line")
  envSnapshot    String    @default("{}") @map("env_snapshot")
  messageLength  Int       @map("message_length")
  systemPrompt   String?   @map("system_prompt_preview")
  resumeToken    String?   @map("resume_token")
  model          String?
  projectPath    String    @map("project_path")
  pid            Int?

  // Raw I/O
  stdoutRaw      String    @default("") @map("stdout_raw")
  stderrRaw      String    @default("") @map("stderr_raw")

  // Timeline
  parsedEvents   String    @default("[]") @map("parsed_events")

  // Timing
  startedAt      DateTime  @map("started_at")
  firstByteAt    DateTime? @map("first_byte_at")
  firstContentAt DateTime? @map("first_content_at")
  completedAt    DateTime? @map("completed_at")
  durationMs     Int?      @map("duration_ms")

  // Result
  exitCode       Int?      @map("exit_code")
  signal         String?
  resultStatus   String    @map("result_status")
  errorMessage   String?   @map("error_message")
  contentLength  Int       @default(0) @map("content_length")
  actionsCount   Int       @default(0) @map("actions_count")
  resumeTokenOut String?   @map("resume_token_out")

  // Token usage (from stream-json)
  inputTokens  Int @default(0) @map("input_tokens")
  outputTokens Int @default(0) @map("output_tokens")
  cacheCreationInputTokens  Int @default(0) @map("cache_creation_input_tokens")
  cacheReadInputTokens      Int @default(0) @map("cache_read_input_tokens")

  // Server tool usage
  webSearchRequests  Int @default(0) @map("web_search_requests")
  webFetchRequests   Int @default(0) @map("web_fetch_requests")

  // Cost and performance
  totalCostUsd     Float?    @map("total_cost_usd")
  durationApiMs    Int?      @map("duration_api_ms")
  numTurns         Int       @default(0) @map("num_turns")
  stopReason       String?   @map("stop_reason")

  // Claude Code metadata
  claudeCodeVersion String?  @map("claude_code_version")
  outputStyle       String?  @map("output_style")
  fastModeState     String?  @map("fast_mode_state")
  permissionMode    String?  @map("permission_mode")
  sessionId         String?  @map("session_id")

  // Additional metadata (JSON fields)
  serviceTier       String?   @map("service_tier")
  inferenceGeo      String?   @map("inference_geo")
  iterations        String?   @default("[]")  // JSON array
  modelUsage        String?   @default("{}")  // JSON object
  permissionDenials String?   @default("[]")  // JSON array
  cacheCreation     String?   @default("{}")  // JSON object (ephemeral_1h, ephemeral_5m)

  createdAt      DateTime  @default(now()) @map("created_at")

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  promptVersionId String? @map("prompt_version_id")

  @@index([executionId])
  @@index([conversationId])
  @@index([stepId])
  @@index([createdAt])
  @@map("execution_traces")
}

// ============================================
// HOOKS (Claude Code Hooks)
// ============================================
model Hook {
  id            String   @id @default(uuid())
  name          String
  description   String?
  eventType     String   @map("event_type") // PreToolUse, PostToolUse, Stop, etc.
  matcher       String?  // regex pattern for matchers (tool name, session type, etc.)
  handlerType   String   @default("command") @map("handler_type") // command | prompt | agent
  command       String?  // shell command (for command handler)
  prompt        String?  // prompt text (for prompt/agent handler)
  timeout       Int      @default(60000) // timeout in ms
  isAsync       Boolean  @default(false) @map("is_async")
  statusMessage String?  @map("status_message") // message shown during execution
  enabled       Boolean  @default(true)
  isGlobal      Boolean  @default(false) @map("is_global")
  projectPath   String?  @map("project_path") // project-specific hook
  isTemplate    Boolean  @default(false) @map("is_template") // system template
  templateId    String?  @map("template_id") // if created from template

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stepHooks     WorkflowStepHook[]

  @@index([userId])
  @@index([eventType])
  @@map("hooks")
}

// ============================================
// USER TOKEN BUDGET
// ============================================
model UserTokenBudget {
  id                  String   @id @default(uuid())
  dailyLimit          Int      @default(5000000) @map("daily_limit")
  monthlyLimit        Int      @default(100000000) @map("monthly_limit")
  currentDailyUsage   Int      @default(0) @map("current_daily_usage")
  currentMonthlyUsage Int      @default(0) @map("current_monthly_usage")
  lastDailyResetAt    DateTime @default(now()) @map("last_daily_reset_at")
  lastMonthlyResetAt  DateTime @default(now()) @map("last_monthly_reset_at")

  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_token_budgets")
}

// ============================================
// STEP TEMPLATES
// ============================================
model StepTemplate {
  id           String   @id @default(uuid())
  name         String
  description  String?
  baseUrl      String   @default("") @map("base_url")
  systemPrompt String?  @map("system_prompt")
  conditions   String   @default("{}")
  resourceIds  String   @default("{}") @map("resource_ids") // JSON {mcpServerIds, skillIds, agentIds, ruleIds, hookIds}
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  userId String @map("user_id")

  @@unique([name, userId])
  @@index([userId])
  @@map("step_templates")
}

// ============================================
// PROMPT VERSIONS
// ============================================
model PromptVersion {
  id        String   @id @default(uuid())
  stepId    String   @map("step_id")
  version   Int
  content   String
  diff      String?
  createdAt DateTime @default(now()) @map("created_at")

  createdBy String @map("created_by")
  creator   User   @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([stepId])
  @@map("prompt_versions")
}

// ============================================
// WEBHOOKS
// ============================================
model Webhook {
  id        String   @id @default(uuid())
  url       String
  events    String   @default("[]") // JSON array of event names
  secret    String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  userId     String            @map("user_id")
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([userId])
  @@map("webhooks")
}

model WebhookDelivery {
  id           String   @id @default(uuid())
  payload      String
  responseCode Int?     @map("response_code")
  responseBody String?  @map("response_body")
  attempts     Int      @default(0)
  status       String   @default("pending") // pending | success | failed
  createdAt    DateTime @default(now()) @map("created_at")
  completedAt  DateTime? @map("completed_at")

  webhookId String  @map("webhook_id")
  webhook   Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@map("webhook_deliveries")
}

// ============================================
// JOIN TABLES
// ============================================
model WorkflowStepMcpServer {
  id       String       @id @default(uuid())
  stepId   String       @map("step_id")
  serverId String       @map("server_id")
  step     WorkflowStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  server   McpServer    @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([stepId, serverId])
  @@map("workflow_step_mcp_servers")
}

model WorkflowStepSkill {
  id      String       @id @default(uuid())
  stepId  String       @map("step_id")
  skillId String       @map("skill_id")
  step    WorkflowStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  skill   Skill        @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([stepId, skillId])
  @@map("workflow_step_skills")
}

model WorkflowStepAgent {
  id      String       @id @default(uuid())
  stepId  String       @map("step_id")
  agentId String       @map("agent_id")
  step    WorkflowStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  agent   Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([stepId, agentId])
  @@map("workflow_step_agents")
}

model WorkflowStepRule {
  id     String       @id @default(uuid())
  stepId String       @map("step_id")
  ruleId String       @map("rule_id")
  step   WorkflowStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  rule   Rule         @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([stepId, ruleId])
  @@map("workflow_step_rules")
}

model WorkflowStepHook {
  id     String       @id @default(uuid())
  stepId String       @map("step_id")
  hookId String       @map("hook_id")
  step   WorkflowStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  hook   Hook         @relation(fields: [hookId], references: [id], onDelete: Cascade)

  @@unique([stepId, hookId])
  @@map("workflow_step_hooks")
}
